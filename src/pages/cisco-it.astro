---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import ImgPlaceholder from '../components/ImgPlaceholder.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';

const features = [
  { icon: '/images/cisco/icons/graduacion.svg', title: 'Uso educativo', desc: 'Diseñado para acompañar el currículo oficial de IT Essentials de Cisco Networking Academy.' },
  { icon: '/images/cisco/icons/escudo-check.svg', title: 'Sin riesgo de daño', desc: 'Permite practicar ensamblaje de componentes sin riesgo de dañar hardware real costoso.' },
  { icon: '/images/cisco/icons/globo-web.svg', title: 'Multiplataforma', desc: 'Corre en cualquier navegador moderno con soporte WebAssembly a través del emulador Ruffle.' },
  { icon: '/images/cisco/icons/gratis.svg', title: 'Gratuito', desc: 'Sin licencias, sin suscripciones, sin costo para los estudiantes de los Cisco Academies.' },
];

const pros = [
  { icon: '/images/cisco/icons/dinero-cancelado.svg', title: 'Costo cero', desc: 'Totalmente gratuito para estudiantes inscritos en Cisco Academy.' },
  { icon: '/images/cisco/icons/refresh.svg', title: 'Práctica ilimitada', desc: 'Repite los procedimientos cuantas veces necesites sin gastar componentes reales.' },
  { icon: '/images/cisco/icons/libro-abierto.svg', title: 'Integrado con el curso', desc: 'Los laboratorios están alineados con el currículo oficial de IT Essentials v7.' },
];

const cons = [
  { icon: '/images/cisco/icons/alerta-triangulo.svg', title: 'Depende de Adobe Flash', desc: 'La aplicación original fue construida en ActionScript/Flash, tecnología descontinuada desde 2020. Solo funciona mediante el emulador Ruffle.' },
  { icon: '/images/cisco/icons/llave-inglesa.svg', title: 'No firmada en algunos OS', desc: 'En macOS requiere abrir desde Preferencias del Sistema la primera vez. Algunas versiones pueden disparar alertas de seguridad.' },
];

const steps = [
  { title: 'Descarga desde Internet Archive', desc: 'Cisco IT Essentials Virtual Desktop NO está disponible oficialmente en NetAcad. La única fuente oficial preservada es Internet Archive: https://archive.org/details/laptop_202008. Descarga el archivo ZIP completo (incluye Laptop y PC Desktop, versión de agosto 2020).', img: '/images/cisco/inst-01-descarga.jpg' },
  { title: 'Extracción del archivo', desc: 'Descomprime el ZIP en una carpeta local con ruta corta, por ejemplo C:\\CiscoIT\\. Esto evita problemas con permisos de Windows y rutas largas.', img: '/images/cisco/inst-02-extraccion.jpg' },
  { title: 'Primera ejecución con Ruffle', desc: 'Si tu navegador no soporta Flash, instala Ruffle (https://ruffle.rs), un emulador open source en Rust. Ruffle detecta automáticamente los archivos .swf y los ejecuta en WebAssembly sin necesidad de plugins.', img: '/images/cisco/inst-04-primer-launch.jpg' },
];

const galleryImages = [
  { label: 'IMG - Pantalla de inicio', caption: 'Pantalla de inicio del simulador Virtual Desktop', ratio: '4/3', src: '/images/cisco/gal-pantalla-inicio.png' },
  { label: 'IMG - Panel frontal del case', caption: 'Paso 1: retirar el panel frontal del case/gabinete', ratio: '4/3', src: '/images/cisco/gal-panel-case.png' },
  { label: 'IMG - Motherboard', caption: 'Paso 2: selección de la motherboard', ratio: '4/3', src: '/images/cisco/gal-motherboard.png' },
  { label: 'IMG - Tarjeta madre instalada', caption: 'Paso 3: instalación de la tarjeta madre en el case', ratio: '4/3', src: '/images/cisco/gal-tarjeta-madre.png' },
  { label: 'IMG - Instalar CPU', caption: 'Paso 4: instalar el procesador (CPU)', ratio: '4/3', src: '/images/cisco/gal-cpu.png' },
  { label: 'IMG - Aplicar pasta térmica', caption: 'Paso 5: aplicación de pasta térmica', ratio: '4/3', src: '/images/cisco/gal-pasta.png' },
  { label: 'IMG - Instalar CPU fan', caption: 'Paso 6: colocar el ventilador del CPU (CPU fan)', ratio: '4/3', src: '/images/cisco/gal-cpu-fan.png' },
  { label: 'IMG - Instalar disipador', caption: 'Paso 7: colocar el disipador sobre el CPU', ratio: '4/3', src: '/images/cisco/gal-disipador.png' },
  { label: 'IMG - Instalar RAM', caption: 'Paso 8: insertar módulos de memoria RAM', ratio: '4/3', src: '/images/cisco/gal-ram.png' },
  { label: 'IMG - Tarjeta NIC', caption: 'Paso 9: instalar la tarjeta de red (NIC)', ratio: '4/3', src: '/images/cisco/gal-nic-real.png' },
  { label: 'IMG - Instalar disco duro', caption: 'Paso 10: instalar disco duro en bahía', ratio: '4/3', src: '/images/cisco/gal-disco.png' },
  { label: 'IMG - Instalar fuente de poder', caption: 'Paso 11: instalar la fuente de poder (PSU)', ratio: '4/3', src: '/images/cisco/gal-fuente.png' },
  { label: 'IMG - Conectar cables de fuente', caption: 'Paso 12: conectar los cables de la fuente a los componentes', ratio: '4/3', src: '/images/cisco/gal-cables-fuente.png' },
  { label: 'IMG - Tarjeta de video', caption: 'Paso 13: instalar tarjeta gráfica (GPU)', ratio: '4/3', src: '/images/cisco/gal-gpu-real.png' },
  { label: 'IMG - Ensamblaje completo', caption: 'Resultado final del ensamblaje', ratio: '4/3', src: '/images/cisco/gal-08-completo.jpg' },
];

const requirements = [
  { name: 'Sistema operativo', value: 'Windows 10/11, macOS 11+, Linux con WebAssembly' },
  { name: 'Navegador recomendado', value: 'Chrome 90+, Firefox 88+, Edge 90+, Safari 14+' },
  { name: 'RAM mínima', value: '2 GB disponibles' },
  { name: 'Espacio en disco', value: '~500 MB (incluye Ruffle si se descarga standalone)' },
  { name: 'Conexión a internet', value: 'Solo para descarga inicial (uso offline después)' },
  { name: 'Permisos', value: 'Usuario estándar (sin admin)' },
];

const videos = [
  { label: 'VIDEO 1', sublabel: 'Ensamblaje completo paso a paso' },
  { label: 'VIDEO 2', sublabel: 'Configuración de BIOS y arranque' },
  { label: 'VIDEO 3', sublabel: 'Diagnóstico y solución de errores comunes' },
];
---
<BaseLayout
  title="Cisco IT Essentials Virtual Desktop — Investigación"
  description="Investigación completa sobre Cisco IT Essentials Virtual Desktop: propósito, ventajas, instalación, requisitos y funcionamiento."
  current="cisco-it"
>

  <!-- Hero — Video de fondo + Colegio arriba + copy promocional -->
  <section class="hero hero--video">
      <!-- Video de fondo: si no existe /videos/hero-cisco.mp4, el poster hace de fallback -->
      <video
        class="hero__video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/images/cisco/hero-poster.jpg"
        aria-hidden="true"
      >
        <source src="/videos/hero-cisco.mp4" type="video/mp4" />
      </video>
      <!-- Tintado oscuro para que el texto blanco sea legible sobre cualquier video -->
      <div class="hero__overlay" aria-hidden="true"></div>
      <!-- Blobs sutiles (opcional, para cohesión con el resto del sitio) -->
      <div class="hero__bg" aria-hidden="true">
        <div class="hero__blob hero__blob--1"></div>
        <div class="hero__blob hero__blob--2"></div>
      </div>
      <div class="container hero__inner">
      <h1 class="hero__title hero__title--light">ENSAMBLÁ TU PC<br/>SIN ROMPER NADA.</h1>
      <p class="hero__subtitle hero__subtitle--light">
        Simulador del curso IT Essentials de Cisco Networking Academy.
        Practicá ensamblaje, configuración y diagnóstico de componentes sin riesgo,
        sin cables y sin gastar un peso en hardware.
      </p>
      <div class="hero__actions">
        <Button href="#introduccion" text="PROBAR EL SIMULADOR AHORA" variant="primary" size="lg" />
        <Button href="#manual" text="VER GALERÍA DE PASOS" variant="ghost" size="lg" />
      </div>
      <div class="hero__scroll-hint" aria-hidden="true">
        <span>Desplazate para explorar</span>
        <svg width="14" height="22" viewBox="0 0 14 22" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="0.5" y="0.5" width="13" height="21" rx="6.5" stroke="white" stroke-opacity="0.6"/>
          <circle class="hero__scroll-dot" cx="7" cy="7" r="2" fill="white"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- 1. Introducción y Propósito -->
  <section id="introduccion" class="section intro-section">
    <div class="container">
      <div class="intro-grid">
        <div>
          <span class="section__eyebrow">01 · Introducción y Propósito</span>
          <h2 class="section__title">¿QUÉ ES EXACTAMENTE?</h2>
          <p class="intro-lead">
            <strong>Cisco IT Essentials Virtual Desktop</strong> es una aplicación interactiva que forma
            parte del curso oficial <em>IT Essentials</em> de Cisco Networking Academy. Su función es
            ofrecer a los estudiantes un entorno virtual donde practicar el ensamblaje, configuración y
            diagnóstico de un equipo de cómputo sin necesidad de manipular hardware físico.
          </p>
          <p class="intro-text">
            Construida originalmente en <strong>Adobe Flash / ActionScript</strong>, la aplicación permitía
            arrastrar y soltar componentes (motherboard, CPU, RAM, disco, fuente) dentro de un chasis
            virtual, completando los procedimientos aprendidos en clase. Tras la descontinuación de Flash
            en 2020, el simulador se mantiene vigente gracias al emulador open source <strong>Ruffle</strong>,
            escrito en Rust y compilado a WebAssembly.
          </p>
          <div class="intro-callout">
            <div class="intro-callout__icon">💡</div>
            <div>
              <strong>¿Cuál es su funcionalidad?</strong> Replicar virtualmente las prácticas de laboratorio
              del curso IT Essentials (v6.0 / v7.0): ensamblaje paso a paso de un PC, instalación de SO,
              configuración de BIOS/UEFI y diagnóstico de fallas comunes.
            </div>
          </div>
        </div>
        <div>
          <img src="/images/cisco/interfaz.jpg" alt="Interfaz del simulador Cisco IT mostrando la instalación de fuente de poder" class="intro-img" />
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Ventajas y Desventajas -->
  <section id="videos" class="section section--purple videos-section">
      <div class="container">
        <span class="purple__eyebrow">02 · Videos demostrativos</span>
        <h2 class="videos-title">MIRA EL SIMULADOR EN ACCIÓN.</h2>
        <p class="videos-desc">
          Videos de YouTube embebidos que se reproducen directamente aquí. Puedes ver tutoriales oficiales
          y demostraciones del ensamblaje paso a paso del Cisco IT Essentials Virtual Desktop.
        </p>

        <div class="videos-grid">
          <div class="video-card">
            <YouTubeEmbed id="6DwEvZzAHYc" title="Ensamblaje virtual PC con Cisco IT Essentials Virtual Desktop" />
            <p class="video-card__title">Ensamblaje virtual de PC paso a paso</p>
          </div>
          <div class="video-card">
            <YouTubeEmbed id="02giRxs3DYM" title="Cisco IT Essentials Virtual Desktop" />
            <p class="video-card__title">Demostración del simulador Cisco IT</p>
          </div>
        </div>
      </div>
    </section>



  <section class="section install-section">
    <div class="container container-narrow">
      <span class="section__eyebrow">03 · Guía de Descarga e Instalación</span>
      <h2 class="section__title">DE DESCARGA A PRIMERA EJECUCIÓN,<br/>EN CUATRO PASOS.</h2>
      <p class="section__lead">
        El proceso es seguro si obtienes los archivos desde fuentes oficiales.
        Aquí tienes el procedimiento detallado.
      </p>

      <div class="steps">
        {steps.map((s, i) => (
          <div class="step">
            <div class="step__num">{String(i + 1).padStart(2, '0')}</div>
            <div class="step__body">
              <h3 class="step__title">{s.title}</h3>
              <p class="step__desc">{s.desc}</p>
              <div class="step__media">
                {s.img ? (
                  <img src={s.img} alt={s.title} class="gallery__img" loading="lazy" />
                ) : (
                  <ImgPlaceholder label={`IMG - paso ${i + 1}`} sublabel={s.title} ratio="16/9" />
                )}
        </div>
            </div>
          </div>
        ))}
      </div>

            <div class="install-cta">
        <h3>¿Listo para descargar?</h3>
        <p>El Cisco IT Essentials Virtual Desktop ya no se distribuye oficialmente por NetAcad. La única copia preservada está en Internet Archive (versión de agosto 2020). Para ejecutarlo en navegadores modernos necesitas Ruffle como emulador de Flash.</p>
        <div class="install-cta__actions">
          <Button href="https://archive.org/details/laptop_202008" text="Descargar de Internet Archive" variant="primary" />
          <Button href="https://ruffle.rs" text="Descargar Ruffle" variant="outline" />
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Requisitos del sistema y licenciamiento -->
  <section class="section section--alt pros-section">
    <div class="container">
      <span class="section__eyebrow">04 · Ventajas y Limitaciones</span>
      <h2 class="section__title">LO BUENO, LO MALO Y LO TÉCNICO.</h2>
      <p class="section__lead">
        Evaluamos la herramienta desde tres perspectivas: educativa, técnica y de usabilidad.
      </p>

      <div class="pros-cons">
        <article class="pros-card">
          <div class="pros-card__head">
            <div class="pros-card__icon pros-card__icon--pros">✓</div>
            <h3>Ventajas</h3>
          </div>
          <ul class="pros-list">
            {pros.map(p => (
              <li>
                <span class="pros-list__icon"><img src={p.icon} alt="" class="pros-list__svg" /></span>
                <div>
                  <strong>{p.title}</strong>
                  <p>{p.desc}</p>
          </div>
              </li>
            ))}
          </ul>
        </article>

        <article class="pros-card pros-card--cons">
          <div class="pros-card__head">
            <div class="pros-card__icon pros-card__icon--cons">!</div>
            <h3>Limitaciones técnicas</h3>
          </div>
          <ul class="pros-list">
            {cons.map(c => (
              <li>
                <span class="pros-list__icon"><img src={c.icon} alt="" class="pros-list__svg" /></span>
                <div>
                  <strong>{c.title}</strong>
                  <p>{c.desc}</p>
          </div>
              </li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- 3. Guía de Descarga e Instalación -->
  <section class="section section--alt reqs-section">
    <div class="container">
      <span class="section__eyebrow">05 · Requisitos del Sistema</span>
      <h2 class="section__title">LO QUE NECESITAS TENER EN TU MÁQUINA.</h2>
      <p class="section__lead">
        Requisitos modestos: la aplicación original en Flash era muy ligera, y Ruffle la ejecuta
        de forma eficiente incluso en equipos modestos.
      </p>

      <div class="reqs-grid">
        <div class="reqs-table">
          <h3>Requisitos técnicos</h3>
          <dl class="reqs-list">
            {requirements.map(r => (
              <div class="reqs-list__row">
                <dt>{r.name}</dt>
                <dd>{r.value}</dd>
        </div>
            ))}
          </dl>
        </div>
        <div class="reqs-license">
          <h3>Licenciamiento</h3>
          <div class="license-card">
            <div class="license-card__badge">GRATUITO</div>
            <h4>Uso educativo libre</h4>
            <p>
              Cisco IT Essentials Virtual Desktop se distribuye sin costo a través del programa
              Cisco Networking Academy para uso educativo. No es software comercial; no requiere
              licencia individual ni activación.
            </p>
            <ul class="license-list">
              <li>✓ Estudiantes matriculados</li>
              <li>✓ Instructores certificados</li>
              <li>✓ Centros académicos autorizados</li>
              <li>✗ Redistribución comercial</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Manual de Funcionamiento Básico -->
  <section id="manual" class="section manual-section">
    <div class="container">
      <span class="section__eyebrow">06 · Manual de Funcionamiento</span>
      <h2 class="section__title">GALERÍA EN 13 PASOS.</h2>
      <p class="section__lead">
        Sigue esta galería visual para completar el ensamblaje completo de un PC de escritorio,
        desde el case vacío hasta el primer arranque. Cada imagen muestra una etapa del proceso.
      </p>

      <div class="gallery">
        {galleryImages.map((img, i) => (
          <figure class="gallery__item">
            {img.src ? (
              <img src={img.src} alt={img.caption} class="gallery__img" loading="lazy" />
            ) : (
              <ImgPlaceholder label={img.label} sublabel={img.caption} ratio={img.ratio} />
            )}
            <figcaption class="gallery__cap">{img.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  </BaseLayout>

<style>
/* ===== HERO — Video de fondo + Colegio arriba + textos claros ===== */
.hero {
  position: relative;
  padding-block: var(--space-9) var(--space-8);
  overflow: hidden;
  isolation: isolate;  /* stacking context para que el video no se filtre */
}
.hero--video { padding-block: var(--space-10) var(--space-8); }
.hero__video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: -2;
  background: #0f0c28;  /* color de fondo mientras carga */
}
.hero__overlay {
  position: absolute;
  inset: 0;
  z-index: -1;
  /* Gradiente oscuro violáceo: denso en el centro, transparente arriba para legibilidad */
  background:
    linear-gradient(180deg,
      rgba(15, 12, 40, 0.55) 0%,
      rgba(15, 12, 40, 0.75) 50%,
      rgba(15, 12, 40, 0.85) 100%),
    radial-gradient(ellipse at center, rgba(49, 36, 107, 0.35) 0%, transparent 70%);
}
.hero__bg { position: absolute; inset: 0; pointer-events: none; z-index: -1; }
.hero__blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(110px);
  opacity: 0.35;
}
.hero__blob--1 {
  width: 680px; height: 680px;
  background: radial-gradient(circle, var(--mesh-violet-2) 0%, transparent 70%);
  top: -160px; left: -140px;
}
.hero__blob--2 {
  width: 520px; height: 520px;
  background: radial-gradient(circle, var(--mesh-violet-3) 0%, transparent 70%);
  bottom: -120px; right: 5%;
}
.hero__inner { position: relative; z-index: 1; text-align: center; max-width: 900px; }

/* Pill del colegio — arriba del H1, discreta y centrada */
.hero__school {
  display: inline-flex;
  align-items: center;
  gap: var(--space-3);
  padding: 0.4rem 1.1rem 0.4rem 0.4rem;
  background: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(255, 255, 255, 0.55);
  border-radius: var(--radius-pill);
  color: var(--color-accent-deep);
  font-size: var(--fs-sm);
  font-weight: 600;
  backdrop-filter: blur(14px) saturate(180%);
  -webkit-backdrop-filter: blur(14px) saturate(180%);
  margin-bottom: var(--space-5);
  box-shadow:
    0 6px 20px rgba(15, 12, 40, 0.40),
    inset 0 1px 0 rgba(255, 255, 255, 0.50);
  transition: background var(--t-fast), transform var(--t-fast);
}
.hero__school:hover {
  background: white;
  color: var(--color-accent-deep);
  transform: translateY(-1px);
}
.hero__school-logo {
  width: 36px; height: 36px;
  display: inline-grid;
  place-items: center;
  border-radius: var(--radius-pill);
  background: white;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 2px 6px rgba(15, 12, 40, 0.25);
}
.hero__school-logo svg { width: 100%; height: 100%; display: block; }
.hero__school-logo img { width: 100%; height: 100%; object-fit: cover; }
.hero__school-name {
  letter-spacing: 0.01em;
  padding-right: var(--space-2);
}

/* Eyebrow — variante clara para fondo oscuro */
.hero__eyebrow {
  display: inline-block; padding: 0.5rem 1.25rem;
  background: rgba(255, 255, 255, 0.10);
  color: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(18px) saturate(200%);
  -webkit-backdrop-filter: blur(18px) saturate(200%);
  border-radius: var(--radius-pill); font-size: var(--fs-sm); font-weight: 700;
  letter-spacing: 0.10em;
  margin-bottom: var(--space-5);
  box-shadow:
    0 6px 20px rgba(15, 12, 40, 0.30),
    inset 0 1px 0 rgba(255, 255, 255, 0.15);
}
.hero__eyebrow--light { color: white; }

/* H1 — variante clara para fondo oscuro */
.hero__title {
  margin-bottom: var(--space-5);
  font-style: italic;
  font-weight: 500;
  color: var(--color-text);
}
.hero__title--light {
  color: white;
  font-weight: 600;
  text-shadow: 0 4px 24px rgba(15, 12, 40, 0.55);
  font-size: clamp(2.5rem, 5vw + 1rem, 4.5rem);
  line-height: 1.05;
  letter-spacing: -0.02em;
}

/* Subtítulo — variante clara */
.hero__subtitle {
  font-size: var(--fs-xl);
  max-width: 680px;
  margin: 0 auto var(--space-6);
  line-height: 1.5;
  padding-inline: var(--space-2);
  color: var(--color-text-muted);
}
.hero__subtitle--light {
  color: rgba(255, 255, 255, 0.92);
  font-weight: 400;
  text-shadow: 0 2px 12px rgba(15, 12, 40, 0.40);
}

.hero__actions {
  display: flex;
  gap: var(--space-3);
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: var(--space-7);
}

/* Hint de scroll */
.hero__scroll-hint {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  color: rgba(255, 255, 255, 0.75);
  font-size: var(--fs-xs);
  letter-spacing: 0.10em;
  text-transform: uppercase;
  font-weight: 600;
}
.hero__scroll-dot {
  animation: scrollBob 1.8s var(--ease-out) infinite;
}
@keyframes scrollBob {
  0%, 100% { transform: translateY(0); opacity: 1; }
  50% { transform: translateY(6px); opacity: 0.6; }
}

.hero__img-wrap { max-width: 900px; margin: var(--space-7) auto 0; }
.hero__img {
  width: 100%;
  max-height: 480px;
  object-fit: contain;
  border-radius: var(--radius-lg);
  border: 1px solid rgba(124, 93, 250, 0.20);
  background: var(--color-accent-soft);
  box-shadow: 0 16px 40px rgba(49, 36, 107, 0.18);
}
.intro-img {
  width: 100%;
  object-fit: contain;
  border-radius: var(--radius-lg);
  border: 1px solid rgba(124, 93, 250, 0.20);
  box-shadow: 0 12px 36px rgba(49, 36, 107, 0.14);
}
.gallery__img {
  width: 100%;
  height: auto;
  max-height: 420px;
  object-fit: contain;
  border-radius: var(--radius-lg);
  border: 1px solid rgba(124, 93, 250, 0.15);
  background: var(--color-accent-soft);
