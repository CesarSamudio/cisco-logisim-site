---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import ImgPlaceholder from '../components/ImgPlaceholder.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';

const features = [
  { icon: '🧩', title: 'Diseñador visual', desc: 'Coloca compuertas, switches, LEDs y circuitos integrados en un canvas con interfaz drag & drop intuitiva.' },
  { icon: '📈', title: 'Cronograma (timing)', desc: 'Visualiza la evolución de señales en el tiempo. Observa cómo cambia cada cable cuando toggleas los switches.' },
  { icon: '⚙️', title: 'Componentes VHDL', desc: 'El comportamiento de los componentes puede especificarse en VHDL, el lenguaje de descripción de hardware estándar.' },
  { icon: '🌍', title: 'Multiplataforma', desc: 'Corre en Windows, macOS y Linux gracias a Java. La misma aplicación funciona idéntica en los tres sistemas.' },
];

const pros = [
  { icon: '🆓', title: 'Open source y libre', desc: 'Licencia GPL, código fuente disponible en GitHub, sin restricciones para uso educativo o investigación.' },
  { icon: '📚', title: 'Librería gigante', desc: 'Componentes TTL, LEDs, switches, displays, SoCs, subcircuitos personalizados. Es el simulador con más componentes listos.' },
  { icon: '🔌', title: 'Integración con hardware', desc: 'Los esquemáticos pueden simularse en placas reales (FPGA, placas FPGA educativas) usando TCL/TK console.' },
];

const cons = [
  { icon: '☕', title: 'Requiere Java 21+', desc: 'La aplicación no arranca si tu sistema no tiene al menos Java 21 instalado. En equipos antiguos puede ser un obstáculo inicial.' },
  { icon: '🍎', title: 'App no firmada en macOS', desc: 'El .dmg de macOS no está firmado con certificado Apple. Hay que aprobar manualmente en Preferencias del Sistema la primera vez.' },
];

const installSteps = [
  { title: 'Elige tu plataforma', desc: 'Visita https://github.com/logisim-evolution/logisim-evolution/releases y descarga el instalador correspondiente a tu sistema operativo (MSI para Windows, DMG para macOS, .deb/.rpm/.snap para Linux).', img: '/images/logisim/inst-01-plataforma.jpg' },
  { title: 'Instala el paquete', desc: 'Ejecuta el instalador con permisos de administrador (Windows/Linux). En macOS, arrastra el .app a la carpeta Aplicaciones y ábrelo desde Preferencias del Sistema la primera vez para aprobarlo.', img: '/images/logisim/inst-02-instala.jpg' },
  { title: 'Verifica Java (opcional)', desc: 'Si usas el JAR portable (logisim-evolution-*-all.jar), asegúrate de tener Java 21+ instalado. Puedes verificar con: java -version en la terminal.', img: '/images/logisim/inst-03-java.jpg' },
  { title: 'Primer lanzamiento', desc: 'Abre la aplicación. Verás un canvas vacío. Coloca un Input, una compuerta AND y un Output desde el panel de componentes para crear tu primer circuito.', img: '/images/logisim/inst-04-launch.jpg' },
];

const galleryImages = [
  { label: 'IMG - File New', caption: 'Crear un nuevo proyecto: File → New', ratio: '4/3', src: '/images/logisim/gal-01-new.jpg' },
  { label: 'IMG - Panel componentes', caption: 'Panel izquierdo con componentes disponibles', ratio: 'auto', src: '/images/logisim/gal-02-panel.jpg' },
  { label: 'IMG - Input Pin', caption: 'Colocar un pin de entrada (Input)', ratio: '4/3', src: '/images/logisim/gal-03-input.jpg' },
  { label: 'IMG - AND gate', caption: 'Insertar compuerta AND desde la librería Gates', ratio: '4/3', src: '/images/logisim/gal-04-and.jpg' },
  { label: 'IMG - Cableado', caption: 'Conexión: Input → AND → Output', ratio: '4/3', src: '/images/logisim/gal-05-cableado.jpg' },
  { label: 'IMG - Toggle switches', caption: 'Cambiar el estado de los switches con clic', ratio: '4/3', src: '/images/logisim/gal-06-toggle.jpg' },
  { label: 'IMG - LED Output', caption: 'Observar el LED encenderse según la lógica', ratio: '4/3', src: '/images/logisim/gal-07-led.jpg' },
];

const requirements = [
  { name: 'Sistema operativo', value: 'Windows 10+, macOS 11+, Linux (cualquier distro reciente)' },
  { name: 'Java Runtime', value: 'Java 21 o superior (incluido en instaladores oficiales)' },
  { name: 'RAM mínima', value: '512 MB (1 GB recomendado para circuitos grandes)' },
  { name: 'Espacio en disco', value: '~200 MB para la aplicación + espacio para proyectos' },
  { name: 'Resolución', value: '1024×768 mínimo (Full HD recomendado)' },
  { name: 'Conexión a internet', value: 'Solo para descarga inicial' },
];

const videos = [
  { label: 'VIDEO 1', sublabel: 'Mi primer circuito: AND gate en 5 minutos' },
  { label: 'VIDEO 2', sublabel: 'Cronograma y simulación temporal' },
  { label: 'VIDEO 3', sublabel: 'Creando un sumador completo con compuertas' },
];

const platformDownloads = [
  { os: 'Windows (Intel/AMD)', file: 'logisim-evolution-X.X.X-amd64.msi', note: 'Instalador estándar' },
  { os: 'Windows (ARM)', file: 'logisim-evolution-X.X.X-aarch64.msi', note: 'Para dispositivos ARM' },
  { os: 'macOS (Apple Silicon)', file: 'logisim-evolution-X.X.X-aarch64.dmg', note: 'Para M1/M2/M3' },
  { os: 'macOS (Intel)', file: 'logisim-evolution-X.X.X-x86_64.dmg', note: 'También corre vía Rosetta' },
  { os: 'Linux (Debian/Ubuntu)', file: 'logisim-evolution_X.X.X-1_amd64.deb', note: 'Paquete Debian' },
  { os: 'Linux (Fedora/Red Hat)', file: 'logisim-evolution-X.X.X-1.x86_64.rpm', note: 'Paquete RPM' },
  { os: 'Cualquier OS', file: 'logisim-evolution-X.X.X-all.jar', note: 'JAR portable (requiere Java 21+)' },
];
---
<BaseLayout
  title="Logisim Evolution — Investigación"
  description="Investigación completa sobre Logisim Evolution: simulador de circuitos lógicos digitales open source en Java."
  current="logisim"
>

  <!-- Hero — Blobs morados -->
  <section class="hero">
      <div class="hero__bg" aria-hidden="true">
        <div class="hero__blob hero__blob--1"></div>
        <div class="hero__blob hero__blob--2"></div>
        <div class="hero__blob hero__blob--3"></div>
        <div class="hero__blob hero__blob--4"></div>
      </div>
      <div class="container hero__inner">
        <span class="hero__eyebrow">Aplicación #2 · Simulador de circuitos</span>
      <h1 class="hero__title">Logisim Evolution.</h1>
      <p class="hero__subtitle">
        Herramienta educativa open source para diseñar y simular circuitos lógicos digitales.
        Construida en Java, multiplataforma, con soporte para VHDL, cronogramas y una librería
        gigante de componentes.
      </p>
      <div class="hero__actions">
        <Button href="#introduccion" text="Comenzar lectura" variant="primary" size="lg" />
        <Button href="#videos" text="Ver videos" variant="outline" size="lg" />
      </div>
      <div class="hero__img-wrap">
        <img src="/images/logisim/hero.jpg" alt="Captura oficial de Logisim Evolution mostrando un circuito complejo" class="hero__img" />
      </div>
    </div>
  </section>

  <!-- 1. Introducción y Propósito -->
  <section id="introduccion" class="section intro-section">
    <div class="container">
      <div class="intro-grid">
        <div>
          <span class="section__eyebrow">01 · INTRODUCCIÓN Y PROPÓSITO</span>
          <h2 class="section__title">¿QUÉ ES Y PARA QUÉ SIRVE?</h2>
          <p class="intro-lead">
            <strong>Logisim Evolution</strong> es un software educativo <em>open source</em> para diseñar
            y simular circuitos lógicos digitales. Es la evolución moderna del clásico Logisim original,
            mantenido por una comunidad activa en GitHub.
          </p>
          <p class="intro-text">
            Permite a estudiantes de ingeniería electrónica, ciencias de la computación y áreas afines
            crear circuitos digitales visualmente — colocar compuertas, switches, LEDs, multiplexores,
            flip-flops y microprocesadores — y simular su comportamiento en tiempo real, todo sin necesidad
            de hardware físico.
          </p>
          <div class="intro-callout">
            <div class="intro-callout__icon">⚡</div>
            <div>
              <strong>¿Cuál es su funcionalidad?</strong> Simular el comportamiento de circuitos digitales
              compuestos por compuertas lógicas (AND, OR, NOT, XOR), circuitos integrados TTL, memorias,
              y hasta CPUs simples. Incluye editor visual, simulación interactiva, cronogramas (timing
              diagrams) y exportación a VHDL.
            </div>
          </div>
        </div>
        <div>
                  <img
                    src="/images/logisim/canva-logisim-evolution.png"
                    alt="Diseño en Canva: Logisim Evolution - herramienta educativa para circuitos digitales"
                    class="intro-canva"
                    loading="lazy"
                  />
                </div>
      </div>
    </div>
  </section>

  <section id="videos" class="section section--purple videos-section">
    <div class="container">
      <span class="purple__eyebrow">02 · VIDEOS DEMOSTRATIVOS</span>
      <h2 class="videos-title">MIRA LOGISIM EN ACCIÓN.</h2>
      <p class="videos-desc">
        Videos de YouTube embebidos que se reproducen directamente aquí. Tutoriales sobre cómo
        instalar Logisim Evolution y construir circuitos básicos desde cero.
      </p>

      <div class="videos-grid">
        <div class="video-card">
          <YouTubeEmbed id="MnpaNTacvU4" title="Micro guía de uso de la herramienta Logisim Evolution" />
          <p class="video-card__title">Micro guía de uso de Logisim Evolution</p>
        </div>
        <div class="video-card">
          <YouTubeEmbed id="cMz7wyY_PxE" title="Logisim Beginner's Tutorial" />
          <p class="video-card__title">Tutorial para principiantes en inglés</p>
        </div>
        <div class="video-card">
          <YouTubeEmbed id="uGrdNJiWjcY" title="Aprende a usar Logisim" />
          <p class="video-card__title">Aprende a usar Logisim (español)</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt pros-section">
    <div class="container">
      <span class="section__eyebrow">03 · VENTAJAS Y LIMITACIONES</span>
      <h2 class="section__title">POR QUÉ DESTACA Y DÓNDE FLAQUEA.</h2>
      <p class="section__lead">
        Logisim Evolution es una de las herramientas más usadas en universidades de todo el mundo.
        Veamos qué lo hace especial y qué puede ser un obstáculo.
      </p>

      <div class="pros-cons">
        <article class="pros-card">
          <div class="pros-card__head">
            <div class="pros-card__icon pros-card__icon--pros">✓</div>
            <h3>Ventajas</h3>
          </div>
          <ul class="pros-list">
            {pros.map(p => (
              <li>
                <span class="pros-list__icon">{p.icon}</span>
                <div>
                  <strong>{p.title}</strong>
                  <p>{p.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </article>

        <article class="pros-card pros-card--cons">
          <div class="pros-card__head">
            <div class="pros-card__icon pros-card__icon--cons">!</div>
            <h3>Limitaciones técnicas</h3>
          </div>
          <ul class="pros-list">
            {cons.map(c => (
              <li>
                <span class="pros-list__icon">{c.icon}</span>
                <div>
                  <strong>{c.title}</strong>
                  <p>{c.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section install-section">
    <div class="container container-narrow">
      <span class="section__eyebrow">04 · GUÍA DE DESCARGA E INSTALACIÓN</span>
      <h2 class="section__title">DESCARGA OFICIAL,<br/>INSTALACIÓN POR PLATAFORMA.</h2>
      <p class="section__lead">
        Logisim Evolution distribuye instaladores nativos para Windows, macOS y Linux, además de un
        JAR portable para sistemas con Java preinstalado.
      </p>

      <div class="downloads">
        <h3>Tabla de descargas por plataforma</h3>
        <div class="downloads-table">
          {platformDownloads.map(d => (
            <div class="downloads-row">
              <div class="downloads-row__os">{d.os}</div>
              <div class="downloads-row__file">
                <code>{d.file}</code>
              </div>
              <div class="downloads-row__note">{d.note}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="steps">
        {installSteps.map((s, i) => (
          <div class="step">
            <div class="step__num">{String(i + 1).padStart(2, '0')}</div>
            <div class="step__body">
              <h3 class="step__title">{s.title}</h3>
              <p class="step__desc">{s.desc}</p>
              <div class="step__media">
                {s.img ? (
                  <img src={s.img} alt={s.title} class="gallery__img" loading="lazy" />
                ) : (
                  <ImgPlaceholder label={`IMG - paso ${i + 1}`} sublabel={s.title} ratio="16/9" />
                )}
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="install-cta">
        <h3>¿Listo para empezar?</h3>
        <p>Descarga la última versión estable desde GitHub Releases.</p>
        <div class="install-cta__actions">
          <Button href="https://github.com/logisim-evolution/logisim-evolution/releases" text="Ir a Releases" variant="primary" />
          <Button href="https://github.com/logisim-evolution/logisim-evolution" text="Ver código fuente" variant="outline" />
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt reqs-section">
    <div class="container">
      <span class="section__eyebrow">05 · REQUISITOS DEL SISTEMA</span>
      <h2 class="section__title">LO QUE NECESITAS EN TU EQUIPO.</h2>
      <p class="section__lead">
        Logisim Evolution es muy ligero. El requisito crítico es tener Java 21+ instalado;
        el resto es modestia pura.
      </p>

      <div class="reqs-grid">
        <div class="reqs-table">
          <h3>Requisitos técnicos</h3>
          <dl class="reqs-list">
            {requirements.map(r => (
              <div class="reqs-list__row">
                <dt>{r.name}</dt>
                <dd>{r.value}</dd>
              </div>
            ))}
          </dl>
        </div>
        <div class="reqs-license">
          <h3>Licenciamiento</h3>
          <div class="license-card">
            <div class="license-card__badge">GPL v3</div>
            <h4>Open source libre</h4>
            <p>
              Logisim Evolution se distribuye bajo la licencia <strong>GNU GPL v3</strong>.
              Esto significa que es completamente gratuito, puedes usarlo con cualquier propósito,
              estudiar su código, modificarlo y redistribuir tus modificaciones.
            </p>
            <ul class="license-list">
              <li>✓ Uso comercial permitido</li>
              <li>✓ Modificación permitida</li>
              <li>✓ Redistribución permitida</li>
              <li>✓ Uso académico sin restricciones</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section manual-section">
    <div class="container">
      <span class="section__eyebrow">06 · MANUAL DE FUNCIONAMIENTO</span>
      <h2 class="section__title">TU PRIMER CIRCUITO EN 7 PASOS.</h2>
      <p class="section__lead">
        Sigue esta galería visual para construir tu primer circuito AND desde cero.
        Cada imagen muestra un paso del proceso.
      </p>

      <div class="gallery">
        {galleryImages.map((img, i) => (
          <figure class="gallery__item">
            {img.src ? (
              <img src={img.src} alt={img.caption} class="gallery__img" loading="lazy" />
            ) : (
              <ImgPlaceholder label={img.label} sublabel={img.caption} ratio={img.ratio} />
            )}
            <figcaption class="gallery__cap">{img.caption}</figcaption>
          </figure>
        ))}
      </div>

      <div class="manual-tips">
        <h3>Tips para empezar rápido</h3>
        <div class="tips-grid">
          <div class="tip-card">
            <span class="tip-card__icon">🖱️</span>
            <strong>Click izquierdo</strong> selecciona, <strong>derecho</strong> abre menú contextual.
          </div>
          <div class="tip-card">
            <span class="tip-card__icon">⌨️</span>
            <strong>Ctrl+Z</strong> para deshacer, <strong>Ctrl+Y</strong> para rehacer.
          </div>
          <div class="tip-card">
            <span class="tip-card__icon">🔍</span>
            <strong>Scroll</strong> para zoom, <strong>Ctrl+0</strong> para ajustar al canvas.
          </div>
          <div class="tip-card">
            <span class="tip-card__icon">📦</span>
            <strong>Project → Load Library</strong> para añadir componentes personalizados.
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ===== HERO — Blobs morados MUY notorios estilo Genway ===== */
.hero { position: relative; padding-block: var(--space-10) var(--space-7); overflow: hidden; }
.hero__bg { position: absolute; inset: 0; pointer-events: none; z-index: 0; }
.hero__blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(110px);
}
.hero__blob--1 {
  width: 680px; height: 680px;
  background: radial-gradient(circle, var(--mesh-violet-2) 0%, transparent 70%);
  top: -160px; left: -140px;
  opacity: 0.85;
}
.hero__blob--2 {
  width: 520px; height: 520px;
  background: radial-gradient(circle, var(--mesh-violet-3) 0%, transparent 70%);
  bottom: -120px; right: 5%;
  opacity: 0.70;
}
.hero__blob--3 {
  width: 400px; height: 400px;
  background: radial-gradient(circle, var(--mesh-violet-1) 0%, transparent 70%);
  top: 30%; right: -80px;
  opacity: 0.60;
}
.hero__blob--4 {
  width: 700px; height: 500px;
  background: radial-gradient(ellipse, rgba(139, 92, 246, 0.40) 0%, transparent 70%);
  top: 20%; left: 50%;
  transform: translateX(-50%);
  opacity: 0.55;
}
.hero__inner { position: relative; z-index: 1; text-align: center; max-width: 900px; }
.hero__eyebrow {
  display: inline-block; padding: 0.5rem 1.25rem;
  background: rgba(255, 255, 255, 0.70);
  color: var(--color-accent-deep);
  border: 1px solid rgba(124, 93, 250, 0.35);
  backdrop-filter: blur(18px) saturate(200%);
  -webkit-backdrop-filter: blur(18px) saturate(200%);
  border-radius: var(--radius-pill); font-size: var(--fs-sm); font-weight: 600;
  margin-bottom: var(--space-5);
  box-shadow:
    0 6px 20px rgba(124, 93, 250, 0.20),
    inset 0 1px 0 rgba(255, 255, 255, 0.70);
}
.hero__title { margin-bottom: var(--space-5); font-style: italic; font-weight: 500; }
.hero__subtitle { font-size: var(--fs-xl); max-width: 680px; margin: 0 auto var(--space-6); line-height: 1.5; padding-inline: var(--space-2); }
.hero__actions { display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap; }
.hero__img-wrap { max-width: 900px; margin: var(--space-7) auto 0; }
.hero__img {
  width: 100%;
  max-height: 520px;
  object-fit: contain;
  border-radius: var(--radius-lg);
  border: 1px solid rgba(124, 93, 250, 0.20);
  background: var(--color-accent-soft);
  box-shadow: 0 16px 40px rgba(49, 36, 107, 0.18);
}
.gallery__img {
  width: 100%;
  height: auto;
  max-height: 360px;
  object-fit: contain;
  border-radius: var(--radius-lg);
  border: 1px solid rgba(124, 93, 250, 0.15);
  background: var(--color-accent-soft);
  padding: var(--space-3);
}

/* ===== SECTION EYEBROWS glass ===== */
.section__eyebrow {
  display: inline-block; padding: 0.35rem 1rem;
  background: rgba(237, 229, 255, 0.85);
  color: var(--color-accent-deep);
  border: 1px solid rgba(124, 93, 250, 0.18);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-radius: var(--radius-pill); font-size: var(--fs-xs); font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: var(--space-4);
}
.section__title { margin-bottom: var(--space-5); font-style: italic; font-weight: 500; }
.section__lead { font-size: var(--fs-lg); line-height: 1.6; margin-bottom: var(--space-7); max-width: 700px; }
.purple__eyebrow {
  display: inline-block; padding: 0.35rem 1rem;
  background: rgba(255, 255, 255, 0.18); color: white;
  border: 1px solid rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  border-radius: var(--radius-pill); font-size: var(--fs-xs); font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: var(--space-4);
}

.intro-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: var(--space-7); align-items: center; }
.intro-grid > div { min-width: 0; }
.intro-lead { font-size: var(--fs-lg); line-height: 1.7; margin-bottom: var(--space-5); color: var(--color-text); }
.intro-text { line-height: 1.7; margin-bottom: var(--space-5); }
.intro-canva {
  width: 100%;
  height: auto;
  border-radius: var(--radius-lg);
  border: 1px solid rgba(124, 93, 250, 0.20);
  background: var(--color-accent-soft);
  padding: var(--space-3);
  box-shadow: 0 12px 36px rgba(49, 36, 107, 0.14);
}
.intro-callout {
  display: flex; gap: var(--space-4);
  padding: var(--space-5);
  background: linear-gradient(135deg, rgba(237, 229, 255, 0.9) 0%, rgba(247, 243, 255, 0.6) 100%);
  border-left: 4px solid var(--color-accent);
  border-radius: var(--radius-md);
  font-size: var(--fs-sm); line-height: 1.6;
  backdrop-filter: blur(8px);
  border: 1px solid rgba(124, 93, 250, 0.15);
  border-left-width: 4px;
}
.intro-callout__icon { font-size: 28px; flex-shrink: 0; }

/* ===== PROS / CONS ===== */
.pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); }
.pros-card {
  padding: var(--space-6);
  background: linear-gradient(180deg, #ffffff 0%, #faf7ff 100%);
  border-radius: var(--radius-xl);
  border: 1px solid rgba(124, 93, 250, 0.18);
  min-width: 0;
}
.pros-card--cons {
  background: linear-gradient(180deg, #fff7f3 0%, #fff 100%);
  border-color: rgba(255, 138, 76, 0.30);
}
.pros-card__head { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-5); }
.pros-card__head h3 { font-size: var(--fs-xl); font-style: italic; font-weight: 500; margin: 0; }
.pros-card__icon {
  display: grid; place-items: center; width: 40px; height: 40px;
  border-radius: var(--radius-pill); font-weight: 700; color: white;
  flex-shrink: 0;
}
.pros-card__icon--pros { background: linear-gradient(135deg, #6abf4b 0%, #4a9c2e 100%); }
