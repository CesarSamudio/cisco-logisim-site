---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import ImgPlaceholder from '../components/ImgPlaceholder.astro';
import Team from '../components/Team.astro';

const apps = [
  {
    id: 'cisco-it',
    name: 'Cisco IT Essentials Virtual Desktop',
    tagline: 'SIMULADOR DE ENSAMBLAJE DE PC',
    headline: 'ENSAMBLÁ UN PC DESDE CERO.',
    pitch: 'Motherboard, CPU, RAM, fuente y GPU. Practicá cada paso sin riesgo, sin cables y sin gastar un peso en hardware.',
    desc: 'Aplicación oficial de Cisco Networking Academy basada en Adobe Flash (ActionScript). Replica virtualmente el ensamblaje, configuración y diagnóstico de un PC de escritorio.',
    href: '/cisco-it',
    icon: '🖥️',
    accent: '#7c5dfa',
    stat: '+6M',
    statLabel: 'estudiantes en Cisco Academy',
  },
  {
    id: 'logisim',
    name: 'Logisim Evolution',
    tagline: 'SIMULADOR DE CIRCUITOS LÓGICOS',
    headline: 'DISEÑÁ CIRCUITOS EN VIVO.',
    pitch: 'Compuertas AND/OR/NOT, sumadores, flip-flops y contadores. Ves la luz encenderse al instante y entendés cómo piensa una computadora por dentro.',
    desc: 'Herramienta educativa open source en Java para diseñar, simular y analizar circuitos digitales. Usada en universidades de todo el mundo.',
    href: '/logisim',
    icon: '⚡',
    accent: '#6332f6',
    stat: '100%',
    statLabel: 'gratis y open source',
  },
];

const trust = [
  { icon: '🎓', label: 'Currículo oficial Cisco Networking Academy' },
  { icon: '💸', label: 'Cero costo, cero licencias, cero suscripciones' },
  { icon: '🛡️', label: 'Cero riesgo de romper hardware real' },
  { icon: '🌐', label: 'Funciona en cualquier navegador moderno' },
];
---
<BaseLayout
  title="Cisco IT · Logisim — Investigación"
  description="Sitio educativo de investigación sobre Cisco IT Essentials Virtual Desktop y Logisim Evolution."
  current="home"
>

  <!-- Hero — Video de fondo + copy promocional -->
  <section class="hero hero--video">
      <video
        class="hero__video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/images/index/hero-index-poster.jpg"
        aria-hidden="true"
      >
        <source src="/videos/hero-index.mp4" type="video/mp4" />
      </video>
      <div class="hero__overlay" aria-hidden="true"></div>
      <div class="hero__bg" aria-hidden="true">
        <div class="hero__blob hero__blob--1"></div>
        <div class="hero__blob hero__blob--2"></div>
        <div class="hero__blob hero__blob--3"></div>
        <div class="hero__blob hero__blob--4"></div>
      </div>
    <div class="container hero__inner">
      <span class="hero__eyebrow">
        <img src="/images/escudo/escudo-tomas-guardia.jpg" alt="" class="hero__school-mark-logo" />
        <span class="hero__school-mark-text">COLEGIO INGENIERO TOMÁS GUARDIA</span>
      </span>
        <h1 class="hero__title hero__title--light">ENSAMBLA PCS.<br/>DISEÑA CIRCUITOS.<br/>PRACTICA SIN ROMPER NI UN CABLE.</h1>
      <p class="hero__subtitle hero__subtitle--light">
        Aprendé a <strong>ensamblar un PC</strong> y a <strong>diseñar circuitos lógicos</strong> sin gastar un peso ni romper un componente. Dos herramientas oficiales, usadas en
        academias de todo el mundo.
      </p>
      <div class="hero__actions">
        <Button href="#apps" text="VER LAS DOS HERRAMIENTAS" variant="primary" size="lg" />
      </div>
      <div class="hero__trust">
        {trust.map(t => (
          <span class="hero__trust-item">
            <span class="hero__trust-icon" aria-hidden="true">{t.icon}</span>
            <span class="hero__trust-label">{t.label}</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Apps Grid — cards con glass + gradient sutil -->
  <section id="apps" class="section apps-section">
    <div class="container">
      <span class="section__eyebrow">APLICACIONES ASIGNADAS</span>
      <h2 class="section__title">LAS DOS HERRAMIENTAS QUE VAS A INVESTIGAR</h2>
      <div class="apps-grid">
        {apps.map(app => (
          <article class="app-card" style={`--card-accent: ${app.accent};`}>
            <div class="app-card__icon">{app.icon}</div>
            <span class="app-card__tag">{app.tagline}</span>
            <h3 class="app-card__name">{app.name}</h3>
            <h4 class="app-card__headline">{app.headline}</h4>
            <p class="app-card__pitch">{app.pitch}</p>
            <p class="app-card__desc">{app.desc}</p>
            <div class="app-card__stat">
              <span class="app-card__stat-num">{app.stat}</span>
              <span class="app-card__stat-label">{app.statLabel}</span>
            </div>
            {app.id === 'cisco-it' ? (
              <img src="/images/index/cisco-captura.jpg" alt="Captura del simulador Cisco IT Essentials Virtual Desktop" class="app-card__img" />
            ) : (
              <img src="/images/index/logisim-captura.jpg" alt="Logo oficial de Logisim Evolution" class="app-card__img" />
            )}
            <a href={app.href} class="app-card__link">
              Ver investigación completa
              <span>→</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>


  <!-- Steps — fondo con mesh gradient -->
  <section class="section steps-section">
    <div class="container container-narrow">
      <span class="section__eyebrow">CÓMO NAVEGAR</span>
      <h2 class="section__title">TRES PASOS PARA EMPEZAR HOY MISMO.</h2>
      <div class="steps">
        <div class="step">
          <div class="step__num">01</div>
          <div class="step__body">
            <h3 class="step__title">Elige una aplicación</h3>
            <p class="step__desc">Comienza por Cisco IT o Logisim desde la sección superior. Cada app tiene su propia página de investigación completa.</p>
          </div>
        </div>
        <div class="step">
          <div class="step__num">02</div>
          <div class="step__body">
            <h3 class="step__title">Revisa los siete criterios</h3>
            <p class="step__desc">Propósito, ventajas, instalación, requisitos, manual y videos están organizados en secciones claras con navegación intuitiva.</p>
          </div>
        </div>
        <div class="step">
          <div class="step__num">03</div>
          <div class="step__body">
            <h3 class="step__title">Compara y concluye</h3>
            <p class="step__desc">Ambas herramientas apuntan a la educación técnica. Encuentra sus diferencias, similitudes y limitaciones documentadas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  </BaseLayout>

<style>
/* ===== HERO — Video de fondo + copy promocional ===== */
.hero {
  position: relative;
  padding-block: var(--space-10) var(--space-9);
  overflow: hidden;
  isolation: isolate;
}
.hero--video { padding-block: var(--space-10) var(--space-8); }
.hero__video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: -2;
  background: #0f0c28;
}
.hero__overlay {
  position: absolute;
  inset: 0;
  z-index: -1;
  /* Mismo degradado morado de los otros heroes — más suave para que se vea el video */
  background:
    linear-gradient(180deg,
      rgba(15, 12, 40, 0.35) 0%,
      rgba(15, 12, 40, 0.50) 50%,
      rgba(15, 12, 40, 0.65) 100%),
    radial-gradient(ellipse at center, rgba(124, 93, 250, 0.25) 0%, transparent 70%);
}
.hero__bg { position: absolute; inset: 0; pointer-events: none; z-index: -1; }
.hero__blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(110px);
  opacity: 0.55;  /* Más visibles que en cisco-it para que se note el degradado */
}
/* Lavanda fuerte arriba-izquierda — el orbe principal */
.hero__blob--1 {
  width: 680px; height: 680px;
  background: radial-gradient(circle, var(--mesh-violet-2) 0%, transparent 70%);
  top: -160px; left: -140px;
}
/* Violeta brillante abajo-derecha — contraste */
.hero__blob--2 {
  width: 520px; height: 520px;
  background: radial-gradient(circle, var(--mesh-violet-3) 0%, transparent 70%);
  bottom: -120px; right: 5%;
}
/* Lavanda medio arriba-derecha */
.hero__blob--3 {
  width: 400px; height: 400px;
  background: radial-gradient(circle, var(--mesh-violet-1) 0%, transparent 70%);
  top: 30%; right: -80px;
  opacity: 0.60;
}
/* Glow violeta central detrás del título */
.hero__blob--4 {
  width: 700px; height: 500px;
  background: radial-gradient(ellipse, rgba(139, 92, 246, 0.40) 0%, transparent 70%);
  top: 20%; left: 50%;
  transform: translateX(-50%);
  opacity: 0.55;
}
.hero__inner {
  position: relative; z-index: 1;
  text-align: center; max-width: 900px;
}

/* ===== SELLO DEL COLEGIO (overlay de fondo, no interactivo) =====
   Posicionado a la izquierda abajo del hero. Bajo opacidad para que sea
   marca de agua y no distraiga del H1. El color se invierte automáticamente
   según el fondo del hero (glass + saturate). */
.hero__school-mark {
  position: absolute;
  bottom: var(--space-7);
  left: var(--space-6);
  z-index: 1;
  display: inline-flex;
  align-items: center;
  gap: var(--space-3);
  padding: 0.5rem 1rem 0.5rem 0.5rem;
  background: rgba(255, 255, 255, 0.55);
  border: 1px solid rgba(255, 255, 255, 0.45);
  border-radius: var(--radius-pill);
  backdrop-filter: blur(12px) saturate(180%);
  -webkit-backdrop-filter: blur(12px) saturate(180%);
  box-shadow:
    0 4px 14px rgba(124, 93, 250, 0.10),
    inset 0 1px 0 rgba(255, 255, 255, 0.55);
  opacity: 0.78;
  pointer-events: none; /* NO interactivo, ni hover, ni link */
}
.hero__school-mark-logo {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-pill);
  background: white;
  object-fit: cover;
  flex-shrink: 0;
  box-shadow: 0 2px 6px rgba(15, 12, 40, 0.20);
}
.hero__school-mark-text {
  font-size: var(--fs-sm);
  font-weight: 700;
  color: var(--color-accent-deep);
  letter-spacing: 0.10em;
  text-transform: uppercase;
  white-space: nowrap;
}

/* Eyebrow pill con logo del colegio (index) */
.hero__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: var(--space-3);
  padding: 0.5rem 1.1rem 0.5rem 0.5rem;
  background: rgba(255, 255, 255, 0.70);
  color: var(--color-accent-deep);
  border: 1px solid rgba(124, 93, 250, 0.35);
  backdrop-filter: blur(18px) saturate(200%);
  -webkit-backdrop-filter: blur(18px) saturate(200%);
  border-radius: var(--radius-pill);
  font-size: var(--fs-sm);
  font-weight: 600;
  margin-bottom: var(--space-5);
  box-shadow:
    0 6px 20px rgba(124, 93, 250, 0.20),
    inset 0 1px 0 rgba(255, 255, 255, 0.70);
  animation: fadeUp 700ms var(--ease-out) both;
}
.hero__title {
  margin-bottom: var(--space-5);
  font-style: italic;
  font-weight: 500;
  animation: fadeUp 800ms 100ms var(--ease-out) both;
}
.hero__title--light {
  color: white;
  font-weight: 600;
  text-shadow: 0 4px 24px rgba(15, 12, 40, 0.55);
  font-size: clamp(2.5rem, 5vw + 1rem, 4.5rem);
  line-height: 1.05;
  letter-spacing: -0.02em;
}
.hero__subtitle {
  font-size: var(--fs-xl);
  max-width: 680px;
  margin: 0 auto var(--space-6);
  line-height: 1.5;
  animation: fadeUp 800ms 200ms var(--ease-out) both;
}
.hero__subtitle--light {
  color: rgba(255, 255, 255, 0.92);
  font-weight: 400;
  text-shadow: 0 2px 12px rgba(15, 12, 40, 0.40);
}
.hero__subtitle--light strong { color: white; font-weight: 700; }
.hero__subtitle strong { color: var(--color-accent); font-weight: 600; }
.hero__actions {
  display: flex; gap: var(--space-3);
  justify-content: center; flex-wrap: wrap;
  animation: fadeUp 800ms 320ms var(--ease-out) both;
}
.section__eyebrow {
  display: inline-block;
  padding: 0.4rem 1.1rem;
  background: rgba(237, 229, 255, 0.85);
  color: var(--color-accent-deep);
  border: 1px solid rgba(124, 93, 250, 0.28);
  backdrop-filter: blur(12px) saturate(180%);
  -webkit-backdrop-filter: blur(12px) saturate(180%);
  border-radius: var(--radius-pill);
  font-size: var(--fs-xs);
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: var(--space-4);
  box-shadow:
    0 4px 14px rgba(124, 93, 250, 0.14),
    inset 0 1px 0 rgba(255, 255, 255, 0.55);
}
.section__title {
  margin-bottom: var(--space-7);
  font-style: italic;
  font-weight: 500;
  max-width: 800px;
}
.purple__eyebrow {
  display: inline-block;
  padding: 0.35rem 1rem;
  background: rgba(255, 255, 255, 0.18);
  color: white;
  border: 1px solid rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  border-radius: var(--radius-pill);
  font-size: var(--fs-xs);
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: var(--space-4);
}

/* ===== APPS GRID ===== */
.apps-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: var(--space-6);
}
.app-card {
  /* Glassmorfismo fuerte — gradient lavanda visible AUN sin backdrop-filter.
     45-55% opacidad para que el morado de atrás se vea claramente.
     blur(18px) en vez de 28px: bastante más rápido sin perder el look glass. */
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.55) 0%, rgba(247, 243, 255, 0.45) 100%);
  backdrop-filter: blur(18px) saturate(180%);
  -webkit-backdrop-filter: blur(18px) saturate(180%);
  border: 1px solid rgba(124, 93, 250, 0.35);
  border-radius: var(--radius-2xl);
  padding: var(--space-6);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  transition:
    transform var(--t-spring),
    box-shadow var(--t-base),
    border-color var(--t-base),
    background var(--t-base);
  position: relative;
  overflow: hidden;
  min-width: 0;  /* prevent grid blowout */
  box-shadow:
    0 8px 32px rgba(49, 36, 107, 0.16),
    0 2px 8px rgba(124, 93, 250, 0.10),
    inset 0 1px 0 rgba(255, 255, 255, 0.85),
    inset 0 -1px 0 rgba(124, 93, 250, 0.08);
  will-change: transform;
}
/* Glow morado en hover */
.app-card::before {
  content: '';
  position: absolute;
  top: -50%; left: -50%;
  width: 200%; height: 200%;
  background: radial-gradient(circle at 50% 0%, rgba(124, 93, 250, 0.10) 0%, transparent 50%);
  opacity: 0;
  transition: opacity var(--t-base);
  pointer-events: none;
}
.app-card:hover {
  transform: translateY(-10px) scale(1.015);
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.78) 0%, rgba(247, 243, 255, 0.68) 100%);
  box-shadow:
    0 28px 70px rgba(49, 36, 107, 0.32),
    0 0 80px rgba(124, 93, 250, 0.25),
    inset 0 1px 0 rgba(255, 255, 255, 0.95);
  border-color: var(--card-accent);
}
.app-card:hover::before { opacity: 1; }
.app-card__icon {
  font-size: 36px;
  display: inline-grid;
  place-items: center;
  width: 60px; height: 60px;
  background: linear-gradient(135deg, rgba(237, 229, 255, 0.95) 0%, rgba(201, 184, 255, 0.95) 100%);
  border: 1px solid rgba(124, 93, 250, 0.30);
  border-radius: var(--radius-lg);
  position: relative;
  z-index: 1;
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.80),
    0 4px 12px rgba(124, 93, 250, 0.18);
}
/* Stagger animation — cards aparecen en cascada */
.app-card { animation: fadeUp 700ms var(--ease-out) both; }
.app-card:nth-child(1) { animation-delay: 100ms; }
.app-card:nth-child(2) { animation-delay: 220ms; }
.step { animation: fadeUp 600ms var(--ease-out) both; }
.step:nth-child(1) { animation-delay: 100ms; }
.step:nth-child(2) { animation-delay: 200ms; }
.step:nth-child(3) { animation-delay: 300ms; }
.app-card__tag {
  font-size: var(--fs-xs);
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--card-accent);
  position: relative;
  z-index: 1;
}
.app-card__name {
  font-size: var(--fs-2xl);
  margin: 0;
  font-style: italic;
  font-weight: 500;
  word-wrap: break-word;
  overflow-wrap: break-word;
  position: relative;
  z-index: 1;
}
.app-card__desc { font-size: var(--fs-sm); line-height: 1.6; position: relative; z-index: 1; }
.app-card__img {
  width: 100%;
  max-height: 220px;
  object-fit: contain;
  border-radius: var(--radius-md);
  border: 1px solid rgba(124, 93, 250, 0.15);
  background: var(--color-accent-soft);
  padding: var(--space-2);
  position: relative;
  z-index: 1;
}
.app-card__link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  margin-top: var(--space-3);
  font-weight: 600;
  color: var(--card-accent);
  position: relative;
  z-index: 1;
}
.app-card__link span { transition: transform var(--t-fast); }
.app-card__link:hover span { transform: translateX(4px); }

/* ===== HEADLINE PROMOCIONAL dentro de la card ===== */
.app-card__headline {
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 600;
  font-size: var(--fs-xl);
  letter-spacing: -0.01em;
  color: var(--color-text);
  margin: var(--space-1) 0 var(--space-2);
  position: relative;
  z-index: 1;
}
.app-card__pitch {
  font-size: var(--fs-base);
  line-height: 1.55;
  color: var(--color-text);
  margin: 0 0 var(--space-3);
  position: relative;
  z-index: 1;
}

/* ===== STAT destacada (social proof ligera) ===== */
.app-card__stat {
  display: flex;
  align-items: baseline;
  gap: var(--space-3);
  padding: var(--space-3) var(--space-4);
  background: linear-gradient(135deg, rgba(237, 229, 255, 0.7) 0%, rgba(247, 243, 255, 0.5) 100%);
  border: 1px solid rgba(124, 93, 250, 0.18);
  border-radius: var(--radius-md);
  position: relative;
  z-index: 1;
}
.app-card__stat-num {
  font-family: var(--font-display);
  font-size: var(--fs-3xl);
  font-weight: 600;
  font-style: italic;
  background: linear-gradient(135deg, var(--card-accent) 0%, var(--color-accent-deep) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  line-height: 1;
}
.app-card__stat-label {
  font-size: var(--fs-sm);
  color: var(--color-text-muted);
  font-weight: 500;
}

/* ===== HERO TRUST BADGES (fila debajo del CTA) ===== */
.hero__trust {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: var(--space-3) var(--space-5);
  margin-top: var(--space-6);
  padding-top: var(--space-6);
  border-top: 1px solid rgba(124, 93, 250, 0.18);
  max-width: 820px;
  margin-inline: auto;
}
.hero__trust-item {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--fs-sm);
  color: var(--color-text-muted);
  font-weight: 500;
}
.hero__trust-icon {
  font-size: 1.1em;
  line-height: 1;
  filter: grayscale(0.1);
}
.hero__trust-label {
  letter-spacing: 0.005em;
}

@media (max-width: 768px) {
  .hero__trust {
    gap: var(--space-2) var(--space-3);
    margin-top: var(--space-5);
    padding-top: var(--space-5);
  }
  .hero__trust-item { font-size: var(--fs-xs); }
  .app-card__stat-num { font-size: var(--fs-2xl); }
}

/* ===== STEPS — ahora con card glass ===== */
.steps {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}
.step {
  display: flex;
  align-items: center;
  gap: var(--space-5);
  padding: var(--space-5) var(--space-6);
  /* Glass card fuerte — gradient lavanda visible. blur 16px para velocidad. */
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.55) 0%, rgba(247, 243, 255, 0.45) 100%);
  backdrop-filter: blur(16px) saturate(180%);
  -webkit-backdrop-filter: blur(16px) saturate(180%);
  border: 1px solid rgba(124, 93, 250, 0.32);
  border-radius: var(--radius-2xl);
  box-shadow:
    0 6px 24px rgba(49, 36, 107, 0.14),
    0 2px 6px rgba(124, 93, 250, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.80);
  transition:
    transform var(--t-spring),
    background var(--t-base),
    box-shadow var(--t-base),
    border-color var(--t-base);
  will-change: transform;
}
.step:hover {
  transform: translateX(10px) scale(1.008);
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.78) 0%, rgba(247, 243, 255, 0.65) 100%);
  box-shadow:
    0 20px 50px rgba(49, 36, 107, 0.26),
    0 0 60px rgba(124, 93, 250, 0.22),
    inset 0 1px 0 rgba(255, 255, 255, 0.95);
  border-color: var(--color-accent);
}
.step__num {
  font-family: var(--font-display);
  font-size: var(--fs-4xl);
  font-style: italic;
  font-weight: 600;
  background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-deep) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  line-height: 1;
  flex-shrink: 0;
  min-width: 60px;
}
.step__body { min-width: 0; flex: 1; }
