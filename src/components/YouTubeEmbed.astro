---
/**
 * YouTubeEmbed — Reproductor de YouTube embebido que se reproduce en la página.
 * Props:
 *   - id: ID del video de YouTube (11 caracteres)
 *   - title: Título del video (para accesibilidad)
 *   - autoplay: true/false (default false)
 */
const { id, title = 'Video de YouTube', autoplay = false } = Astro.props;
const src = autoplay
  ? `https://www.youtube.com/embed/${id}?autoplay=1&rel=0`
  : `https://www.youtube.com/embed/${id}?rel=0`;
---
<div class="yt-embed">
  <iframe
    src={src}
    title={title}
    frameborder="0"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
    loading="lazy"
  ></iframe>
</div>

<style>
.yt-embed {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: #000;
  box-shadow: var(--shadow-card);
  border: 1px solid var(--color-border);
}
.yt-embed iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: 0;
}
</style>