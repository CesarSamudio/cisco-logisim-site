---
const {
  variant = 'primary',
  href,
  text,
  size = 'md',
} = Astro.props;
const Tag = href ? 'a' : 'button';
---
<Tag
  href={href}
  class:list={['btn', `btn--${variant}`, `btn--${size}`]}
>
  <span class="btn__text">{text}<slot /></span>
  {variant === 'primary' && <span class="btn__arrow">→</span>}
</Tag>

<style>
/* === BASE === */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  border: none;
  cursor: pointer;
  font-family: var(--font-body);
  font-weight: 600;
  border-radius: var(--radius-pill);
  transition: transform var(--t-base), box-shadow var(--t-base), background var(--t-base);
  text-decoration: none;
  white-space: nowrap;
  font-size: var(--fs-base);
  position: relative;
  isolation: isolate;
  -webkit-tap-highlight-color: transparent;
}
.btn--sm { padding: 0.5rem 1.1rem; font-size: var(--fs-sm); }
.btn--md { padding: 0.8rem 1.6rem; }
.btn--lg { padding: 1rem 2.2rem; font-size: var(--fs-lg); }

/* === PRIMARY — Glassmorfismo morado MUY visible ===
   Combinación: gradient violeta + backdrop-filter + border highlight + shine */
.btn--primary {
  background:
    linear-gradient(135deg, rgba(124, 93, 250, 0.95) 0%, rgba(91, 59, 214, 0.95) 100%);
  color: white;
  border: 1.5px solid rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(20px) saturate(200%);
  -webkit-backdrop-filter: blur(20px) saturate(200%);
  box-shadow:
    0 8px 28px rgba(91, 59, 214, 0.45),         /* glow externo morado */
    0 2px 6px rgba(124, 93, 250, 0.30),         /* sombra cercana */
    inset 0 1px 0 rgba(255, 255, 255, 0.40),    /* highlight superior (glass) */
    inset 0 -1px 0 rgba(0, 0, 0, 0.10);         /* sombra inferior interna */
  overflow: hidden;
}

/* Capa de shine animada al hacer hover */
.btn--primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 60%;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(
    120deg,
    transparent 0%,
    rgba(255, 255, 255, 0.45) 50%,
    transparent 100%
  );
  opacity: 0;
  transition: opacity var(--t-base);
  pointer-events: none;
  z-index: 1;
}

/* Reflejo sutil permanente (vidrio) */
.btn--primary::after {
  content: '';
  position: absolute;
  inset: 1px;
  border-radius: inherit;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.18) 0%,
    transparent 50%
  );
  pointer-events: none;
  z-index: 0;
}

.btn--primary:hover {
  background:
    linear-gradient(135deg, rgba(140, 110, 255, 1) 0%, rgba(105, 75, 230, 1) 100%);
  color: white;
  transform: translateY(-3px);
  box-shadow:
    0 14px 38px rgba(91, 59, 214, 0.55),
    0 4px 10px rgba(124, 93, 250, 0.35),
    inset 0 1px 0 rgba(255, 255, 255, 0.55),
    inset 0 -1px 0 rgba(0, 0, 0, 0.12);
}
.btn--primary:hover::before {
  opacity: 1;
  animation: shine 1.1s var(--ease);
}
.btn--primary:active { transform: translateY(-1px); }

@keyframes shine {
  0% { left: -100%; }
  100% { left: 130%; }
}

/* === OUTLINE — Glass transparente con borde violeta ===
   Mucho más visible: backdrop-filter real + tinte violeta en el borde */
.btn--outline {
  background: rgba(255, 255, 255, 0.55);
  color: var(--color-accent);
  border: 1.5px solid var(--color-accent);
  backdrop-filter: blur(18px) saturate(180%);
  -webkit-backdrop-filter: blur(18px) saturate(180%);
  box-shadow:
    0 4px 16px rgba(124, 93, 250, 0.15),
    inset 0 1px 0 rgba(255, 255, 255, 0.6);
}
.btn--outline:hover {
  background: rgba(255, 255, 255, 0.80);
  color: var(--color-accent-deep);
  transform: translateY(-3px);
  border-color: var(--color-accent-deep);
  box-shadow:
    0 10px 28px rgba(124, 93, 250, 0.30),
    inset 0 1px 0 rgba(255, 255, 255, 0.7);
}
.btn--outline:active { transform: translateY(-1px); }

/* === GHOST — Glass blanco puro (para fondos oscuros) === */
.btn--ghost {
  background: rgba(255, 255, 255, 0.12);
  color: white;
  border: 1.5px solid rgba(255, 255, 255, 0.40);
  backdrop-filter: blur(16px) saturate(160%);
  -webkit-backdrop-filter: blur(16px) saturate(160%);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.25);
}
.btn--ghost:hover {
  background: rgba(255, 255, 255, 0.22);
  border-color: rgba(255, 255, 255, 0.60);
  color: white;
  transform: translateY(-2px);
}

.btn__text { position: relative; z-index: 2; }
.btn__arrow { position: relative; z-index: 2; transition: transform var(--t-fast); }
.btn:hover .btn__arrow { transform: translateX(4px); }

/* Mobile: botones full-width opcional en hero cuando se apilan */
@media (max-width: 480px) {
  .btn--lg { padding: 0.9rem 1.4rem; font-size: var(--fs-base); }
}
</style>