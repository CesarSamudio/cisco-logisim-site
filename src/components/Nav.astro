---
const { current = 'home' } = Astro.props;
const links = [
  { id: 'home', href: '/', label: 'Inicio' },
  { id: 'cisco-it', href: '/cisco-it', label: 'Cisco IT' },
  { id: 'logisim', href: '/logisim', label: 'Logisim' },
  { id: 'creadores', href: '/creadores', label: 'Creadores' },
];
---
<nav class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo">
      <span class="nav__logo-mark">⌬</span>
      <span class="nav__logo-text">Cisco · Logisim</span>
    </a>

    <ul class="nav__pill">
      {links.map(l => (
        <li>
          <a
            href={l.href}
            class:list={['nav__link', { 'nav__link--active': current === l.id }]}
          >{l.label}</a>
        </li>
      ))}
    </ul>

    <a href="/#apps" class="nav__cta">Comenzar →</a>
  </div>
</nav>

<style>
.nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(249, 249, 251, 0.85);
  backdrop-filter: saturate(180%) blur(12px);
  -webkit-backdrop-filter: saturate(180%) blur(12px);
  border-bottom: 1px solid var(--color-border);
}
.nav__inner {
  max-width: var(--container-max);
  margin-inline: auto;
  height: var(--nav-height);
  padding-inline: var(--space-5);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-5);
}
.nav__logo {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-display);
  font-size: var(--fs-lg);
  font-weight: 600;
  color: var(--color-text);
  font-style: italic;
}
.nav__logo-mark {
  display: inline-grid;
  place-items: center;
  width: 32px; height: 32px;
  background: var(--color-accent);
  color: white;
  border-radius: var(--radius-pill);
  font-style: normal;
  font-size: 18px;
  box-shadow: var(--shadow-soft);
}
.nav__pill {
  display: flex;
  list-style: none;
  padding: 4px;
  margin: 0;
  background: white;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-pill);
  gap: 2px;
}
.nav__link {
  display: inline-block;
  padding: 0.45rem 1rem;
  font-size: var(--fs-sm);
  font-weight: 500;
  color: var(--color-text-muted);
  border-radius: var(--radius-pill);
  transition: all var(--t-fast);
}
.nav__link:hover {
  color: var(--color-accent);
  background: var(--color-accent-soft);
}
.nav__link--active {
  background: var(--color-accent);
  color: white;
}
.nav__link--active:hover {
  background: var(--color-accent-hover);
  color: white;
}
.nav__cta {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: 0.6rem 1.25rem;
  background: var(--color-accent);
  color: white;
  border-radius: var(--radius-pill);
  font-size: var(--fs-sm);
  font-weight: 600;
  box-shadow: var(--shadow-soft);
  transition: all var(--t-fast);
}
.nav__cta:hover {
  background: var(--color-accent-hover);
  color: white;
  transform: translateY(-1px);
  box-shadow: var(--shadow-card);
}

@media (max-width: 768px) {
  .nav__pill { display: none; }
  .nav__logo-text { display: none; }
}
</style>
