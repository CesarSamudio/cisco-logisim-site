---
const { current = 'home' } = Astro.props;
const links = [
  { id: 'home', href: '/', label: 'Inicio' },
  { id: 'cisco-it', href: '/cisco-it', label: 'Cisco IT' },
  { id: 'logisim', href: '/logisim', label: 'Logisim' },
  { id: 'creadores', href: '/creadores', label: 'Creadores' },
];
---
<nav class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo">
      <span class="nav__logo-mark">⌬</span>
      <span class="nav__logo-text">Cisco · Logisim</span>
    </a>

    <ul class="nav__pill">
      {links.map(l => (
        <li>
          <a
            href={l.href}
            class:list={['nav__link', { 'nav__link--active': current === l.id }]}
          >{l.label}</a>
        </li>
      ))}
    </ul>

    <a href="/#apps" class="nav__cta">Comenzar →</a>
  </div>
</nav>

<style>
.nav {
  position: sticky;
  top: 0;
  z-index: 100;
  /* Glassmorfismo intensificado: tinte violeta visible + blur fuerte + highlight superior.
     blur 18px en vez de 28px — bastante más rápido sin perder glass. */
  background: rgba(247, 243, 255, 0.78);
  backdrop-filter: saturate(180%) blur(18px);
  -webkit-backdrop-filter: saturate(180%) blur(18px);
  border-bottom: 1px solid rgba(124, 93, 250, 0.22);
  box-shadow:
    0 6px 28px rgba(49, 36, 107, 0.10),
    inset 0 1px 0 rgba(255, 255, 255, 0.65);
}
.nav__inner {
  max-width: var(--container-max);
  margin-inline: auto;
  height: var(--nav-height);
  padding-inline: var(--space-5);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-5);
}
.nav__logo {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-display);
  font-size: var(--fs-lg);
  font-weight: 600;
  color: var(--color-text);
  font-style: italic;
  flex-shrink: 0;
}
.nav__logo-mark {
  display: inline-grid;
  place-items: center;
  width: 34px; height: 34px;
  background: var(--gradient-primary);
  color: white;
  border-radius: var(--radius-pill);
  font-style: normal;
  font-size: 18px;
  box-shadow:
    0 6px 18px rgba(91, 59, 214, 0.55),
    inset 0 1px 0 rgba(255, 255, 255, 0.40);
  flex-shrink: 0;
}
.nav__pill {
  display: flex;
  list-style: none;
  padding: 5px;
  margin: 0;
  background: rgba(255, 255, 255, 0.50);
  border: 1px solid rgba(124, 93, 250, 0.20);
  border-radius: var(--radius-pill);
  gap: 2px;
  backdrop-filter: blur(14px) saturate(180%);
  -webkit-backdrop-filter: blur(14px) saturate(180%);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55);
}
.nav__link {
  display: inline-block;
  padding: 0.5rem 1.1rem;
  font-size: var(--fs-sm);
  font-weight: 500;
  color: var(--color-text-muted);
  border-radius: var(--radius-pill);
  transition: all var(--t-fast);
}
.nav__link:hover {
  color: var(--color-accent);
  background: var(--color-accent-soft);
}
.nav__link--active {
  background: var(--gradient-primary);
  color: white;
  box-shadow:
    0 4px 14px rgba(91, 59, 214, 0.45),
    inset 0 1px 0 rgba(255, 255, 255, 0.35);
}
.nav__link--active:hover {
  background: linear-gradient(135deg, var(--color-accent-hover) 0%, var(--color-accent-deep) 100%);
  color: white;
}
.nav__cta {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: 0.65rem 1.35rem;
  background: var(--gradient-primary);
  color: white;
  border-radius: var(--radius-pill);
  font-size: var(--fs-sm);
  font-weight: 600;
  border: 1.5px solid rgba(255, 255, 255, 0.30);
  box-shadow:
    0 8px 24px rgba(91, 59, 214, 0.50),
    inset 0 1px 0 rgba(255, 255, 255, 0.45),
    inset 0 -1px 0 rgba(0, 0, 0, 0.12);
  transition: all var(--t-fast);
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}
.nav__cta::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.22) 0%, transparent 60%);
  pointer-events: none;
}
.nav__cta:hover {
  color: white;
  transform: translateY(-2px);
  box-shadow:
    0 12px 32px rgba(91, 59, 214, 0.65),
    inset 0 1px 0 rgba(255, 255, 255, 0.55),
    inset 0 -1px 0 rgba(0, 0, 0, 0.15);
}

@media (max-width: 768px) {
  .nav { backdrop-filter: saturate(200%) blur(22px); }
  .nav__pill { display: none; }
  .nav__logo-text { display: none; }
  .nav__inner { gap: var(--space-3); padding-inline: var(--space-4); }
}
</style>