---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <div class="footer__logo">
        <span class="footer__logo-mark">⌬</span>
        <span>Cisco · Logisim</span>
      </div>
      <p class="footer__tag">Investigación educativa · IT Essentials & Circuitos Digitales</p>
    </div>

    <div class="footer__cols">
      <div class="footer__col">
        <h4 class="footer__col-title">Proyecto</h4>
        <ul class="footer__col-list">
          <li><a href="/" class="footer__link">Portada</a></li>
          <li><a href="/cisco-it" class="footer__link">Cisco IT</a></li>
          <li><a href="/logisim" class="footer__link">Logisim</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__col-title">Recursos</h4>
        <ul class="footer__col-list">
          <li>
            <a href="https://archive.org/details/laptop_202008" class="footer__link" target="_blank" rel="noopener">Internet Archive</a>
          </li>
          <li>
            <a href="https://github.com/logisim-evolution/logisim-evolution" class="footer__link" target="_blank" rel="noopener">Logisim GitHub</a>
          </li>
        </ul>
      </div>

      </div>
  </div>

  <div class="footer__bottom">
    <p>© {year} · Sitio educativo de investigación · Construido con Astro</p>
  </div>
</footer>

<style>
.footer {
  background: var(--color-dark);
  color: var(--color-dark-text);
  padding-block: var(--space-8) var(--space-5);
  margin-top: var(--space-10);
}
.footer__inner {
  max-width: var(--container-max);
  margin-inline: auto;
  padding-inline: var(--space-5);
  display: grid;
  grid-template-columns: 1.3fr 3fr;
  gap: var(--space-7);
}
.footer__logo {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-display);
  font-size: var(--fs-xl);
  color: white;
  font-style: italic;
  margin-bottom: var(--space-3);
}
.footer__logo-mark {
  display: inline-grid;
  place-items: center;
  width: 36px; height: 36px;
  background: var(--color-accent);
  color: white;
  border-radius: var(--radius-pill);
  font-style: normal;
}
.footer__tag {
  font-size: var(--fs-sm);
  max-width: 280px;
  line-height: 1.5;
}

.footer__cols {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-5);
}
.footer__col-title {
  font-family: var(--font-body);
  font-size: var(--fs-xs);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: white;
  margin-bottom: var(--space-4);
  font-weight: 700;
}
.footer__col-list { list-style: none; padding: 0; margin: 0; }
.footer__col-list li { margin-bottom: var(--space-2); }
.footer__link {
  color: var(--color-dark-text);
  font-size: var(--fs-sm);
  transition: color var(--t-fast);
}
.footer__link:hover { color: white; }
.footer__bottom {
  max-width: var(--container-max);
  margin: var(--space-7) auto 0;
  padding-inline: var(--space-5);
  border-top: 1px solid rgba(255,255,255,0.08);
  padding-top: var(--space-4);
  text-align: center;
  font-size: var(--fs-xs);
}

@media (max-width: 768px) {
  .footer__inner { grid-template-columns: 1fr; gap: var(--space-6); }
  .footer__cols { grid-template-columns: repeat(2, 1fr); gap: var(--space-5); }
}
</style>