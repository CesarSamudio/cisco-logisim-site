---
const team = [
  {
    name: 'César Samudio',
    role: 'Desarrollador',
    photo: '/images/team/cesar.jpg',
    initials: 'CS',
  },
  {
    name: 'Caleb Duarte',
    role: 'Administrador de imágenes',
    photo: '/images/team/caleb.jpeg',
    initials: 'CD',
  },
];
---

<section id="equipo" class="section team-section">
  <div class="container">
    <span class="section__eyebrow">Equipo de investigación</span>
    <h2 class="section__title">Las personas detrás del sitio.</h2>
    <p class="section__lead">
      Dos estudiantes de IT Essentials investigando las herramientas que usan a diario.
      Documentamos con rigor lo que encontramos y lo compartimos aquí.
    </p>

    <div class="team-grid">
      {team.map(member => (
        <article class="team-card">
        <div class="team-card__photo">
          <img
            src={member.photo}
            alt={`Foto de ${member.name}`}
            class="team-card__img"
          />
        </div>
        <h3 class="team-card__name">{member.name}</h3>
        <p class="team-card__role">{member.role}</p>
      </article>
      ))}
    </div>
  </div>
</section>

<style>
.team-section {
  position: relative;
  background:
    radial-gradient(ellipse 500px 300px at 50% 0%, rgba(237, 229, 255, 0.6) 0%, transparent 70%),
    linear-gradient(180deg, var(--color-accent-softer) 0%, #ffffff 100%);
  overflow: hidden;
}

.section__eyebrow {
  display: inline-block;
  padding: 0.4rem 1.1rem;
  background: rgba(237, 229, 255, 0.85);
  color: var(--color-accent-deep);
  border: 1px solid rgba(124, 93, 250, 0.28);
  backdrop-filter: blur(12px) saturate(180%);
  -webkit-backdrop-filter: blur(12px) saturate(180%);
  border-radius: var(--radius-pill);
  font-size: var(--fs-xs);
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: var(--space-4);
  box-shadow:
    0 4px 14px rgba(124, 93, 250, 0.14),
    inset 0 1px 0 rgba(255, 255, 255, 0.55);
}

.section__title {
  margin-bottom: var(--space-5);
  font-style: italic;
  font-weight: 500;
  max-width: 800px;
}

.section__lead {
  font-size: var(--fs-lg);
  line-height: 1.6;
  margin-bottom: var(--space-7);
  max-width: 700px;
  color: var(--color-text-muted);
}

.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: var(--space-6);
  max-width: 720px;
}

.team-card {
  /* Glass card fuerte estilo Genway */
  background: rgba(255, 255, 255, 0.62);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1px solid rgba(124, 93, 250, 0.25);
  border-radius: var(--radius-2xl);
  padding: var(--space-6);
  text-align: center;
  transition: all var(--t-base);
  position: relative;
  overflow: hidden;
  min-width: 0;
  box-shadow:
    0 8px 32px rgba(49, 36, 107, 0.16),
    inset 0 1px 0 rgba(255, 255, 255, 0.70);
}
.team-card::before {
  content: '';
  position: absolute;
  top: -50%; left: -50%;
  width: 200%; height: 200%;
  background: radial-gradient(circle at 50% 0%, rgba(124, 93, 250, 0.18) 0%, transparent 50%);
  opacity: 0;
  transition: opacity var(--t-base);
  pointer-events: none;
}
.team-card:hover {
  transform: translateY(-8px);
  background: rgba(255, 255, 255, 0.78);
  box-shadow:
    0 24px 60px rgba(49, 36, 107, 0.28),
    0 0 60px rgba(124, 93, 250, 0.20);
  border-color: var(--color-accent);
}
.team-card:hover::before { opacity: 1; }

.team-card__photo {
  width: 140px;
  height: 140px;
  margin: 0 auto var(--space-5);
  border-radius: 50%;
  overflow: hidden;
  background: var(--color-accent-soft);
  position: relative;
  border: 3px solid var(--color-accent-soft);
  box-shadow:
    0 0 0 4px rgba(124, 93, 250, 0.15),
    0 8px 24px rgba(124, 93, 250, 0.30);
  z-index: 1;
}

.team-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.team-card__placeholder {
  width: 100%;
  height: 100%;
  display: grid;
  place-items: center;
  font-family: var(--font-display);
  font-size: 3rem;
  font-weight: 600;
  color: var(--color-accent);
  font-style: italic;
}

.team-card__name {
  font-size: var(--fs-xl);
  margin: 0 0 var(--space-2);
  font-style: italic;
  font-weight: 500;
  color: var(--color-text);
  position: relative;
  z-index: 1;
}

.team-card__role {
  font-size: var(--fs-sm);
  color: var(--color-accent);
  font-weight: 600;
  letter-spacing: 0.04em;
  margin: 0;
  position: relative;
  z-index: 1;
}

@media (max-width: 600px) {
  .team-grid { grid-template-columns: 1fr; max-width: 320px; margin-inline: auto; }
}
</style>