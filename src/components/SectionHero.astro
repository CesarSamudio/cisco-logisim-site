---
const {
  eyebrow,
  title,
  subtitle,
  variant = 'default',
} = Astro.props;
---
<section class:list={['hero', `hero--${variant}`]}>
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__blob hero__blob--1"></div>
    <div class="hero__blob hero__blob--2"></div>
    <div class="hero__blob hero__blob--3"></div>
  </div>
  <div class="container hero__inner">
    {eyebrow && <span class="hero__eyebrow">{eyebrow}</span>}
    <h1 class="hero__title">{title}</h1>
    {subtitle && <p class="hero__subtitle">{subtitle}</p>}
    <div class="hero__actions">
      <slot name="actions" />
    </div>
    <div class="hero__media">
      <slot name="media" />
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  padding-block: var(--space-9) var(--space-8);
  overflow: hidden;
}
.hero__bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}
.hero__blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.4;
}
.hero__blob--1 {
  width: 400px; height: 400px;
  background: radial-gradient(circle, #f9d4ff 0%, transparent 70%);
  top: -100px; left: -100px;
}
.hero__blob--2 {
  width: 300px; height: 300px;
  background: radial-gradient(circle, #d4e4ff 0%, transparent 70%);
  bottom: -50px; right: 10%;
}
.hero__blob--3 {
  width: 250px; height: 250px;
  background: radial-gradient(circle, #fff0d4 0%, transparent 70%);
  top: 30%; right: -50px;
}
.hero--purple {
  background: var(--color-accent-deep);
  color: white;
}
.hero--purple .hero__title,
.hero--purple .hero__subtitle { color: white; }
.hero--purple .hero__subtitle { color: rgba(255,255,255,0.85); }
.hero--purple .hero__blob { opacity: 0.25; }

.hero__inner {
  position: relative;
  z-index: 1;
  text-align: center;
  max-width: 900px;
}
.hero__eyebrow {
  display: inline-block;
  padding: 0.4rem 1rem;
  background: var(--color-accent-soft);
  color: var(--color-accent);
  border-radius: var(--radius-pill);
  font-size: var(--fs-sm);
  font-weight: 600;
  margin-bottom: var(--space-4);
}
.hero--purple .hero__eyebrow {
  background: rgba(255,255,255,0.15);
  color: white;
}
.hero__title {
  margin-bottom: var(--space-5);
  font-style: italic;
  font-weight: 500;
}
.hero__subtitle {
  font-size: var(--fs-xl);
  max-width: 640px;
  margin: 0 auto var(--space-6);
  line-height: 1.5;
}
.hero__actions {
  display: flex;
  gap: var(--space-3);
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: var(--space-7);
}
.hero__media {
  max-width: 1000px;
  margin-inline: auto;
}
</style>
