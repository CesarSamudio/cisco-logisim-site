---
const {
  label = 'IMG',
  sublabel = '',
  ratio = '16/9',
  variant = 'default',
} = Astro.props;
---
<div class:list={['img-ph', `img-ph--${variant}`]} style={`aspect-ratio: ${ratio};`}>
  <div class="img-ph__inner">
    <svg class="img-ph__icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <circle cx="9" cy="9" r="2"/>
      <path d="m21 15-5-5L5 21"/>
    </svg>
    <span class="img-ph__label">{label}</span>
    {sublabel && <span class="img-ph__sub">{sublabel}</span>}
  </div>
</div>

<style>
.img-ph {
  width: 100%;
  border: 2px dashed var(--color-accent);
  background: var(--color-accent-soft);
  background-image:
    linear-gradient(135deg, rgba(124, 93, 250, 0.04) 25%, transparent 25%),
    linear-gradient(225deg, rgba(124, 93, 250, 0.04) 25%, transparent 25%);
  background-size: 24px 24px;
  background-position: 0 0, 12px 0;
  border-radius: var(--radius-lg);
  display: grid;
  place-items: center;
  color: var(--color-accent);
  position: relative;
  overflow: hidden;
  transition: all var(--t-fast);
}
.img-ph:hover {
  background-color: rgba(124, 93, 250, 0.12);
  border-color: var(--color-accent-hover);
}
.img-ph--purple {
  border-color: rgba(255,255,255,0.5);
  background: rgba(255,255,255,0.08);
  background-image:
    linear-gradient(135deg, rgba(255,255,255,0.05) 25%, transparent 25%),
    linear-gradient(225deg, rgba(255,255,255,0.05) 25%, transparent 25%);
  color: white;
}
.img-ph--dark {
  background: var(--color-dark);
  border-color: rgba(255,255,255,0.15);
  color: white;
}
.img-ph__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  text-align: center;
  padding: var(--space-4);
}
.img-ph__icon {
  opacity: 0.7;
}
.img-ph__label {
  font-family: var(--font-display);
  font-size: var(--fs-lg);
  font-weight: 600;
  font-style: italic;
  letter-spacing: 0.02em;
}
.img-ph__sub {
  font-size: var(--fs-sm);
  opacity: 0.7;
  max-width: 220px;
  line-height: 1.4;
}
</style>
