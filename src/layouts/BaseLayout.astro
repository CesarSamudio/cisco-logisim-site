---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const {
  title = 'Cisco IT · Logisim — Investigación',
  description = 'Sitio educativo de investigación sobre Cisco IT Essentials Virtual Desktop y Logisim Evolution.',
  current = 'home',
} = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500;1,9..144,600&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav current={current} />
    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      (function () {
        var nav = document.querySelector('.nav');
        if (!nav) return;

        // Sentinel: 1px pegado al top del body, antes del nav.
        // Mientras su top relativo al viewport sea >= 0 -> el nav está en zona visible -> mostrar.
        // Cuando top < 0 -> el nav salió por arriba -> aplicar hide/show según dirección de scroll.
        var sentinel = document.createElement('div');
        sentinel.setAttribute('aria-hidden', 'true');
        sentinel.style.cssText = 'position:absolute;top:0;left:0;width:1px;height:1px;pointer-events:none;';
        document.body.insertBefore(sentinel, document.body.firstChild);

        var lastY = window.scrollY || window.pageYOffset || 0;
        var hidden = false;
        var DELTA = 4;

        function setHidden(state) {
          if (state === hidden) return;
          hidden = state;
          if (state) nav.classList.add('nav--hidden');
          else nav.classList.remove('nav--hidden');
        }

        function update() {
          var y = window.scrollY || window.pageYOffset || 0;
          var diff = y - lastY;
          var sentinelTop = sentinel.getBoundingClientRect().top;

          if (sentinelTop >= 0) {
            // Top del documento -> siempre visible
            setHidden(false);
          } else {
            // Sentinel fuera de viewport
            if (diff > DELTA) {
              setHidden(true);  // scrolleando hacia abajo -> ocultar
            } else if (diff < -DELTA) {
              setHidden(false); // scrolleando hacia arriba -> mostrar
            }
            // diff dentro del DELTA (micro-movimiento) -> mantener estado actual
          }
          lastY = y;
        }

        // passive: true para no bloquear el scroll del usuario
        window.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update, { passive: true });

        // Estado inicial
        update();
      })();
    </script>
  </body>
</html>
