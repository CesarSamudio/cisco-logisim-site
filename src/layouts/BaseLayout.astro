---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const {
  title = 'Cisco IT · Logisim — Investigación',
  description = 'Sitio educativo de investigación sobre Cisco IT Essentials Virtual Desktop y Logisim Evolution.',
  current = 'home',
} = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500;1,9..144,600&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav current={current} />
    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      // ====================================================================
      // HEADER STICKY INTELIGENTE — versión ULTRA ROBUSTA
      // Patrón Vercel/Stripe: rAF loop continuo + try/catch + console.log
      // ====================================================================
      (function () {
        'use strict';

        function init() {
          var nav = document.querySelector('.nav');
          if (!nav) {
            console.warn('[nav-sticky] .nav no encontrado');
            return;
          }

          var TOP_THRESHOLD = 80;     // si estamos dentro de los primeros 80px -> siempre visible
          var lastY = window.pageYOffset || document.documentElement.scrollTop || 0;
          var hidden = false;
          var debug = false; // cambiar a true si querés ver los logs en consola

          function setHidden(state) {
            if (state === hidden) return;
            hidden = state;
            if (state) nav.classList.add('nav--hidden');
            else nav.classList.remove('nav--hidden');
            if (debug) console.log('[nav-sticky] hidden=' + state);
          }

          function update() {
            var y = window.pageYOffset || document.documentElement.scrollTop || 0;
            var diff = y - lastY;

            if (y <= TOP_THRESHOLD) {
              // Top del documento -> siempre visible
              setHidden(false);
            } else if (diff > 0) {
              // Scroll hacia abajo -> ocultar
              setHidden(true);
            } else if (diff < 0) {
              // Scroll hacia arriba (cualquier cantidad) -> mostrar
              setHidden(false);
            }
            // diff === 0 (no se movió este frame) -> no hacer nada, mantener estado

            lastY = y;
          }

          // requestAnimationFrame loop — corre a 60fps, no por evento scroll
          // Más robusto que addEventListener('scroll') porque:
          //  1. No se pierden frames intermedios
          //  2. Se ejecuta en el thread de render, no bloquea scroll
          //  3. Compatible con TODOS los navegadores modernos (Brave/Chrome/Firefox/Safari)
          var ticking = false;
          function onScroll() {
            if (!ticking) {
              window.requestAnimationFrame(function () {
                try {
                  update();
                } catch (e) {
                  console.error('[nav-sticky] update error:', e);
                }
                ticking = false;
              });
              ticking = true;
            }
          }

          // passive: true para no bloquear el scroll del usuario
          window.addEventListener('scroll', onScroll, { passive: true });
          window.addEventListener('resize', onScroll, { passive: true });

          // Estado inicial — verificar al cargar la página (ej: si recargás scrolleado)
          try { update(); } catch (e) { console.error('[nav-sticky] init error:', e); }

          // Debug: exponer al usuario para verificar en consola
          window.__navSticky = {
            getState: function () { return { hidden: hidden, scrollY: lastY, threshold: TOP_THRESHOLD }; },
            show:     function () { setHidden(false); },
            hide:     function () { setHidden(true); },
          };

          console.log('[nav-sticky] initialized. Try window.__navSticky.getState() in console.');
        }

        // Esperar a que el DOM esté listo
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>
  </body>
</html>
