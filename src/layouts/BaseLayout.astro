---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const {
  title = 'Cisco IT · Logisim — Investigación',
  description = 'Sitio educativo de investigación sobre Cisco IT Essentials Virtual Desktop y Logisim Evolution.',
  current = 'home',
} = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500;1,9..144,600&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav current={current} />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // ===== HEADER INTELIGENTE: oculta al bajar, muestra al subir =====
      // Sentinel en el top del <main>: cuando es visible -> nav visible (estamos arriba).
      // Cuando no es visible -> nav oculto por defecto.
      // Scroll direction detector: si el sentinel salió por arriba y el usuario scrollea
      // hacia abajo, ocultar. Si el usuario scrollea hacia arriba (y el sentinel sigue fuera),
      // mostrar de nuevo, así puede llegar a "Inicio" sin tener que ir al top absoluto.
      (() => {
        const nav = document.querySelector('.nav');
        if (!nav) return;

        // Sentinel: un div invisible de 1px justo después del nav.
        // Cuando la parte SUPERIOR del viewport pasa el sentinel, sabemos que el usuario
        // ha scrolleado fuera del área del header.
        const sentinel = document.createElement('div');
        sentinel.setAttribute('aria-hidden', 'true');
        sentinel.style.cssText = 'position:absolute;top:0;left:0;width:1px;height:1px;pointer-events:none;';
        document.body.prepend(sentinel);

        const rectOf = (el) => el.getBoundingClientRect();

        let hidden = false;
        let lastY = window.scrollY;
        const DELTA = 4; // píxeles mínimos para considerar cambio de dirección

        const setHidden = (state) => {
          if (state === hidden) return;
          hidden = state;
          nav.classList.toggle('nav--hidden', state);
        };

        const update = () => {
          const y = window.scrollY;
          const diff = y - lastY;

          // Posición del sentinel relativa al viewport
          const sentinelTop = rectOf(sentinel).top;

          if (sentinelTop >= 0) {
            // El sentinel está visible -> estamos en el top -> siempre mostrar
            setHidden(false);
          } else {
            // El sentinel ya pasó por arriba del viewport
            if (diff > DELTA) {
              setHidden(true);  // bajando -> ocultar
            } else if (diff < -DELTA) {
              setHidden(false); // subiendo -> mostrar
            }
            // Si diff está dentro de DELTA (micro-scroll), mantener estado anterior
          }
          lastY = y;
        };

        // passive listener para no bloquear scroll
        window.addEventListener('scroll', update, { passive: true });
        // Llamada inicial para estado correcto
        update();
      })();
    </script>
  </body>
</html>
